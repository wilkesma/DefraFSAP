plot.scen.msi <- function(){
x <- scen.opt.nat
x$rest.scen <- "Water body-specific"
x$rest.scen.short <- "WB*"
y <- scen.nat[scen.nat$species=="MSI",-which(colnames(scen.nat) %in% c("scen", "species"))]
x <- rbind(x[,colnames(y)], y)
x$rest.scen <- factor(x$rest.scen, levels=c(levels(scen.nat$rest.scen), "Water body-specific"))
x$clim.scen <- factor(x$clim.scen, levels=unique(x$clim.scen))
x$yint <- mean(base.nat$fit[base.nat$species=="MSI"])
x$diff <- (x$fit-x$yint)/x$yint*100
x$diff.lwr <- (x$lwr-x$yint)/x$yint*100
x$diff.upr <- (x$upr-x$yint)/x$yint*100
x$rest.scen.short <- factor(x$rest.scen.short, levels=c(rest.scen.short.order, "WB*"))
x$p <- 100-apply(x, 1, function(y) pnorm(0, mean=as.numeric(y["diff"]), sd=abs(as.numeric(y["diff.lwr"])-as.numeric(y["diff"])), lower.tail=TRUE))*100
x$p[x$year==2042] <- 100-apply(x[x$year==2042,], 1, function(y) pnorm(10, mean=as.numeric(y["diff"]), sd=abs(as.numeric(y["diff.lwr"])-as.numeric(y["diff"])), lower.tail=TRUE))*100
p <- ggplot(x, aes(x=as.character(year), y=p)) +
geom_bar(stat="identity") +
labs(y="Probability of achieving species abundance target (%)") +
scale_y_continuous(limits=c(0,80), breaks=seq(0,80,by=20))+
geom_hline(yintercept=50, linetype=2) +
facet_grid(clim.scen~rest.scen.short) +
theme(strip.text.x=element_text(angle=90, hjust=0), axis.text.x = element_text(angle = 90, vjust = 0.5, hjust=1),
axis.title.x=element_blank())
print(p)
}
